  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@preact/preset-vite": "^2.10.5",
    "canvas": "^3.2.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
