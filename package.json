{
  "name": "plummet",
  "version": "1.2.1",
  "description": "A falling-letter word puzzle game",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dedupe:words": "node dedupe-words.js",
    "export:distinct-words": "node dedupe-words.js --output distinct-words.js",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "ios": "npm run build && npx cap sync ios && npx cap open ios",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "icons": "node generate-icons.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-updater": "^8.45.8",
    "@esotericsoftware/spine-canvas": "^4.2.109",
    "@esotericsoftware/spine-core": "^4.2.109",
    "@esotericsoftware/spine-phaser": "^4.1.56",
    "@esotericsoftware/spine-webgl": "^4.2.109",
    "@supabase/supabase-js": "^2.101.1",
    "an-array-of-english-words": "^2.0.0",
    "chance": "^1.1.13",
    "chart.js": "^4.5.1",
    "dom-autoscroller": "^2.3.4",
    "english-word-list": "^1.0.5",
    "ftscroller": "^0.7.0",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "iscroll": "^5.2.0",
    "kaboom": "^3000.1.17",
    "loot-table": "^0.1.0",
    "mathjs": "^15.1.1",
    "matter-js": "^0.20.0",
    "openskill": "^4.1.1",
    "phaser": "^3.90.0",
    "pixi.js": "^8.17.1",
    "planck": "^1.4.3",
    "popular-english-words": "^1.0.2",
    "preact": "^10.29.0",
    "trie-search": "^2.2.1",
    "weighted": "^1.0.0",
    "word-list-json": "^0.2.0",
    "wordnet-db": "^3.1.14",
    "wordsearch-generator": "^1.3.3",
    "zustand": "^5.0.12"
